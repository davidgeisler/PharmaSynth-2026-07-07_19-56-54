%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Final_WineMaking
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: final-winemaking
  moduleTitle: 'Final 4: Wine Making'
  intendedLearningOutcomes:
  - Prepare a fermenting must from fruit, sugar and yeast
  - Confirm fermentation by CO2 evolution (limewater)
  - Rack and evaluate the finished wine (appearance, clarity, flavour)
  tasks: []
  graphTasks:
  - taskId: prepare-must
    label: "Prepare the must \u2014 fruit juice (not grapes) + sugar + yeast (250\u2013500
      mL)"
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: Dissolve sugar in the fruit juice and pitch the yeast.
  - taskId: seal-airlock
    label: Seal the vessel with an airlock / balloon
    phase: 1
    prerequisites:
    - prepare-must
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: Fit the airlock so CO2 escapes but air cannot enter.
  - taskId: confirm-co2
    label: "Confirm fermentation \u2014 CO2 turns limewater milky"
    phase: 2
    prerequisites:
    - seal-airlock
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Bubble the evolved gas through limewater; it turns milky.
  - taskId: ferment-timeskip
    label: "Ferment \u20187 days & 7 nights\u2019 (time-skip)"
    phase: 1
    prerequisites:
    - confirm-co2
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: Let fermentation run to completion (time-skip montage).
  - taskId: rack
    label: Rack the wine off the lees
    phase: 1
    prerequisites:
    - ferment-timeskip
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: Siphon the clear wine off the sediment.
  - taskId: test-clarity
    label: Assess clarity and appearance
    phase: 2
    prerequisites:
    - rack
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Judge colour and clarity against the standard.
  - taskId: test-tasting
    label: "Tasting finale \u2014 evaluate flavour"
    phase: 2
    prerequisites:
    - rack
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Evaluate aroma and flavour at the tasting finale.
  - taskId: record-label
    label: Create the label and record volume & observations
    phase: 3
    prerequisites:
    - test-clarity
    - test-tasting
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: Design the label and log the final volume and notes.
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.2
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills: 
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 600
