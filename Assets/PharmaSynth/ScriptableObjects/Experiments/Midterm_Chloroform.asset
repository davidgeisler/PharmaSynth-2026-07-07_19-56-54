%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Midterm_Chloroform
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: midterm-chloroform
  moduleTitle: 'Midterm 4: Chloroform'
  intendedLearningOutcomes:
  - Prepare chloroform by the haloform reaction of acetone with bleaching powder
  - Purify by decantation and distillation over CaCl2
  - Confirm by non-flammability and alcoholic silver-nitrate tests
  tasks: []
  graphTasks:
  - taskId: prep-bleach
    label: Dissolve 150 g bleaching powder in 400 mL water (1 L flask)
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: Shake until the bleaching powder dissolves.
  - taskId: prep-acetone-mix
    label: Mix 12 g acetone + 50 mL water in a separatory funnel
    phase: 0
    prerequisites:
    - prep-bleach
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: Prepare the acetone-water mixture for dropwise addition.
  - taskId: reflux-setup
    label: Connect the flask to a reflux condenser
    phase: 1
    prerequisites:
    - prep-bleach
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: Fit the reflux condenser before adding acetone.
  - taskId: add-dropwise
    label: Add the acetone-water mixture dropwise
    phase: 1
    prerequisites:
    - reflux-setup
    - prep-acetone-mix
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: Add slowly through the condenser; the reaction is exothermic.
  - taskId: distil
    label: Distil off the crude chloroform
    phase: 1
    prerequisites:
    - add-dropwise
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: Rearrange for distillation and collect the dense chloroform layer.
  - taskId: decant-wash
    label: "Wash by decantation with water (\xD72)"
    phase: 1
    prerequisites:
    - distil
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: Decant off the water twice to wash the chloroform.
  - taskId: dry-redistil
    label: Dry over CaCl2 and redistil until clear
    phase: 1
    prerequisites:
    - decant-wash
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: Dry with anhydrous calcium chloride, then redistil to a clear liquid.
  - taskId: test-flammability
    label: Non-flammability test
    phase: 2
    prerequisites:
    - dry-redistil
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Chloroform does not readily burn \u2014 unlike the acetone feedstock."
  - taskId: test-agno3
    label: Alcoholic AgNO3 (no precipitate cold)
    phase: 2
    prerequisites:
    - dry-redistil
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Alcoholic silver nitrate gives no precipitate in the cold with chloroform.
  - taskId: record-yield
    label: Record % yield and observations
    phase: 3
    prerequisites:
    - test-flammability
    - test-agno3
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: Enter chloroform mass, % yield and test results.
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.2
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills: 
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 1100
