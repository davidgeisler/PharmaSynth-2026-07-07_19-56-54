%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Final_Caffeine
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: final-caffeine
  moduleTitle: 'Final 3: Caffeine (from tea)'
  intendedLearningOutcomes:
  - Extract caffeine from tea using a base and solvent extraction
  - Purify caffeine by sublimation
  - Confirm identity by the murexide test and melting point
  tasks: []
  graphTasks:
  - taskId: brew-tea
    label: Boil tea leaves with sodium carbonate
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: Sodium carbonate frees caffeine from tannins during boiling.
  - taskId: filter-brew
    label: Filter the hot tea liquor
    phase: 1
    prerequisites:
    - brew-tea
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: Filter off the leaves while hot.
  - taskId: extract-dcm
    label: Extract with dichloromethane in a separatory funnel (fume hood)
    phase: 1
    prerequisites:
    - filter-brew
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: Shake with DCM; caffeine partitions into the organic layer. Work in the
      fume hood.
  - taskId: dry-na2so4
    label: Dry the DCM extract over anhydrous Na2SO4
    phase: 1
    prerequisites:
    - extract-dcm
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: Dry the solvent with sodium sulfate, then decant.
  - taskId: evaporate
    label: Evaporate the solvent to crude caffeine
    phase: 1
    prerequisites:
    - dry-na2so4
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: Evaporate the DCM to leave crude caffeine.
  - taskId: sublime
    label: Purify crystals by sublimation
    phase: 1
    prerequisites:
    - evaporate
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: Gently sublime to obtain pure white caffeine needles.
  - taskId: test-murexide
    label: Murexide test (purple residue)
    phase: 2
    prerequisites:
    - sublime
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Evaporate with HCl + H2O2, then expose to ammonia; a purple colour confirms
      caffeine.
  - taskId: test-meltingpoint
    label: "Melting point (~234\u2013236 \xB0C)"
    phase: 2
    prerequisites:
    - sublime
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "A sharp melting point near 235 \xB0C confirms purity."
  - taskId: record-yield
    label: Record % yield and observations
    phase: 3
    prerequisites:
    - test-murexide
    - test-meltingpoint
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: Enter caffeine mass, % yield and test results.
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.2
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills: 
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 1000
