  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Prelim_ChemicalCompounding
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: prelim-chemical-compounding
  moduleTitle: 'Prelim: Chemical Compounding'
  intendedLearningOutcomes:
  - Identify functional groups by characteristic reactions
  - Interpret combustion, metal, halogen and oxidation tests
  - Record observations accurately
  tasks: []
  graphTasks:
  - taskId: gather-ethanol
    label: Gather ethanol and test reagents
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: Collect ethanol, sodium, bromine water and KMnO4.
  - taskId: test-combustion
    label: Combustion test (clean flame)
    phase: 2
    prerequisites:
    - gather-ethanol
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Ignite a little ethanol; note the flame.
  - taskId: test-sodium
    label: Reaction with sodium (H2 evolved)
    phase: 2
    prerequisites:
    - gather-ethanol
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Add a small piece of sodium; watch for effervescence.
  - taskId: test-bromine
    label: Bromine water test
    phase: 2
    prerequisites:
    - gather-ethanol
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Add bromine water; note any decolourisation.
  - taskId: test-kmno4
    label: "Oxidation with KMnO4 (purple\u2192brown)"
    phase: 2
    prerequisites:
    - gather-ethanol
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: Add dilute KMnO4; watch the colour change.
  - taskId: record-observations
    label: Record observations on the data sheet
    phase: 3
    prerequisites:
    - test-combustion
    - test-sodium
    - test-bromine
    - test-kmno4
    progressWeight: 1
    skill: 5
    rubricCategory: 5
    required: 1
    hint: Note each test result on your tablet.
