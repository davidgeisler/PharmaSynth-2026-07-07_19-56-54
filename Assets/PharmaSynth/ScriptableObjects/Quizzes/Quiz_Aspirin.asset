--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2aaa93f2aa9be4d4babad2427d4a3c02, type: 3}
  m_Name: Quiz_Aspirin
  m_EditorClassIdentifier: Assembly-CSharp::QuizBank
  moduleId: final-aspirin
  questions:
  - prompt: 'Aspirin is made by acetylating salicylic acid with:'
    options:
    - Acetone
    - Acetic anhydride
    - Ethanol
    - Sodium hydroxide
    correctIndex: 1
    explanation: Acetic anhydride acetylates the phenol group.
  - prompt: 'A purple colour with ferric chloride means the aspirin is:'
    options:
    - Pure
    - Overheated only
    - Impure (salicylic acid remains)
    - Perfectly acetylated
    correctIndex: 2
    explanation: "Purple indicates unreacted salicylic acid (free phenol) \u2014
      impure."
  - prompt: 'Overheating the water bath during synthesis causes:'
    options:
    - Decomposition of the product
    - A higher yield
    - Faster crystallisation
    - A purer product
    correctIndex: 0
    explanation: "Excess heat chars/decomposes the product \u2014 a failed batch."
