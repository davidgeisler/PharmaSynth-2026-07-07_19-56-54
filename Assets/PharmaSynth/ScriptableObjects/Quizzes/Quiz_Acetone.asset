  m_Script: {fileID: 11500000, guid: 2aaa93f2aa9be4d4babad2427d4a3c02, type: 3}
  m_Name: Quiz_Acetone
  m_EditorClassIdentifier: Assembly-CSharp::QuizBank
  moduleId: midterm-acetone
  questions:
  - prompt: 'Acetone is prepared by dry distillation of:'
    options:
    - Sodium chloride
    - Acetate salts
    - Sugar
    - Limestone
    correctIndex: 1
    explanation: Calcium/sodium acetate decompose to acetone.
  - prompt: 'The acetone fraction is collected at about:'
    options:
    - 100 C
    - 78 C
    - 56 C
    - 150 C
    correctIndex: 2
    explanation: Acetone boils at 56 degrees.
  - prompt: 'Acetone is a ketone, so Tollen''s test is:'
    options:
    - Negative
    - Positive
    - Explosive
    - Yellow
    correctIndex: 0
    explanation: Ketones do not reduce Tollen's reagent (no silver mirror).
