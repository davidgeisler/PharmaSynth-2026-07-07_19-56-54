  m_Script: {fileID: 11500000, guid: 2aaa93f2aa9be4d4babad2427d4a3c02, type: 3}
  m_Name: Quiz_EthylAlcohol
  m_EditorClassIdentifier: Assembly-CSharp::QuizBank
  moduleId: prelim-ethyl-alcohol
  questions:
  - prompt: 'Fermentation of sugar by yeast produces ethanol and:'
    options:
    - Oxygen
    - Carbon dioxide
    - Hydrogen
    - Methane
    correctIndex: 1
    explanation: CO2 is the by-product, confirmed by limewater turning milky.
  - prompt: At roughly what temperature is the ethanol fraction distilled?
    options:
    - 30-40 C
    - 100-110 C
    - 70-80 C
    - 150-160 C
    correctIndex: 2
    explanation: Ethanol boils ~78 degrees; the 70-80 cut is collected.
  - prompt: 'A positive iodoform test gives a precipitate that is:'
    options:
    - Yellow
    - White
    - Black
    - Blue
    correctIndex: 0
    explanation: Iodoform (CHI3) is a yellow precipitate.
