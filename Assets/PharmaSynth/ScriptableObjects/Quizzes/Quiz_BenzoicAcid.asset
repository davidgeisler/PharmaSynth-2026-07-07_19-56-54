  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2aaa93f2aa9be4d4babad2427d4a3c02, type: 3}
  m_Name: Quiz_BenzoicAcid
  m_EditorClassIdentifier: Assembly-CSharp::QuizBank
  moduleId: midterm-benzoic-acid
  questions:
  - prompt: 'Benzoic acid is prepared here by oxidising:'
    options:
    - Toluene
    - Benzaldehyde
    - Phenol
    - Aniline
    correctIndex: 1
    explanation: Benzaldehyde is oxidised by dilute KMnO4 to benzoic acid.
  - prompt: 'The brown solid filtered off after oxidation is:'
    options:
    - Carbon
    - Iron oxide
    - Manganese dioxide
    - Silver
    correctIndex: 2
    explanation: Reduced permanganate leaves manganese dioxide (MnO2).
  - prompt: Why acidify the filtrate with HCl?
    options:
    - To precipitate benzoic acid
    - To dissolve crystals
    - To add colour
    - To neutralise nothing
    correctIndex: 0
    explanation: It converts soluble benzoate back to insoluble benzoic acid.
