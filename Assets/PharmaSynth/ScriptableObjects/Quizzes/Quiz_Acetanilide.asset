  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2aaa93f2aa9be4d4babad2427d4a3c02, type: 3}
  m_Name: Quiz_Acetanilide
  m_EditorClassIdentifier: Assembly-CSharp::QuizBank
  moduleId: midterm-acetanilide
  questions:
  - prompt: 'Acetanilide is formed by acetylating:'
    options:
    - Phenol
    - Aniline
    - Benzene
    - Toluene
    correctIndex: 1
    explanation: Aniline's -NH2 is acetylated to the amide.
  - prompt: Why must aniline be handled in the fume hood?
    options:
    - It is flammable only
    - It is harmless
    - It is toxic and volatile
    - It is radioactive
    correctIndex: 2
    explanation: Aniline is toxic and volatile.
  - prompt: Acetanilide contains which functional group?
    options:
    - Amide
    - Alcohol
    - Ketone
    - Ester
    correctIndex: 0
    explanation: The product is an amide.
