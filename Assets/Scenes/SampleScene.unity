  m_Script: {fileID: 11500000, guid: 42642937fbd237f48a1b4931b9e13c83, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LabTourGuide
  player: {fileID: 0}
  speakCooldown: 3.5
  stops:
  - landmarkName: DynamicStage
    beat: "This bench is your main workspace. Flick your wrist face-up and glance
      at it \u2014 your holographic procedures board appears with every step, live.
      The progress bar and timer up top track your pace."
    radius: 2.2
  - landmarkName: EquipmentShelf
    beat: "The equipment cabinet \u2014 open it and pick the apparatus your procedures
      board calls for. Flick your wrist anytime to check the next step."
    radius: 2
  - landmarkName: ReagentShelf
    beat: "The reagent shelf holds your chemicals \u2014 take only what each step
      needs. And Settings up top lets you tune audio, text size and comfort whenever
      you like."
    radius: 2
  introBeat: "Welcome! Let's take a quick tour. The bench in the middle is your main
    workspace \u2014 walk around and I'll point out the rest as you reach them."
  closerBeat: That's the tour! Follow the glowing markers during a run, and poke
    me whenever you're ready to take on a graded campaign.
